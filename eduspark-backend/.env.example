# EduSpark 后端环境变量配置

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=eduspark

# JWT
JWT_SECRET=change-this-to-a-random-string

# iFlytek Spark
SPARK_APP_ID=your_app_id
SPARK_API_SECRET=your_api_secret
SPARK_API_KEY=your_api_key

# iFlytek Image
IMAGE_API_KEY=your_image_api_key

# iFlytek TTS
TTS_APP_ID=your_tts_app_id
TTS_API_KEY=your_tts_api_key

# SeeDance
SEEDANCE_API_KEY=your_seedance_api_key

# Storage (local | oss)
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage/files

# OSS (only needed if STORAGE_TYPE=oss)
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_BUCKET=
# OSS_ENDPOINT=
