# EduSpark 后端环境变量配置

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash

# SQLite（开发环境默认，无需额外配置）
# 生产环境用 MySQL 时，取消下面注释：
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/eduspark?charset=utf8mb4

# JWT
JWT_SECRET=change-this-to-a-random-string

# Storage (local | oss)
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage/files

# OSS (only needed if STORAGE_TYPE=oss)
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_BUCKET=
# OSS_ENDPOINT=
